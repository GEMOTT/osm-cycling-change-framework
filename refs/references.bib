	note = {3 citations (Semantic Scholar/arXiv) [2025-11-05]
arXiv:2210.02350 [cs]},
	keywords = {Computer Science - Computers and Society},
	annote = {Comment: ASSETS 2022 UrbanAccess Workshop},
	file = {Full Text PDF:/home/eugenividaltortosa/snap/zotero-snap/common/Zotero/storage/WRBIQBK5/Omar et al. - 2022 - Crowdsourcing and Sidewalk Data A Preliminary Study on the Trustworthiness of OpenStreetMap Data in.pdf:application/pdf;Snapshot:/home/eugenividaltortosa/snap/zotero-snap/common/Zotero/storage/R8EKEV8W/2210.html:text/html},
