@article{szell_growing_2022,
	title = {Growing urban bicycle networks},
	volume = {12},
	copyright = {2022 The Author(s)},
	issn = {2045-2322},
	url = {https://www.nature.com/articles/s41598-022-10783-y},
	doi = {10.1038/s41598-022-10783-y},
	abstract = {Cycling is a promising solution to unsustainable urban transport systems. However, prevailing bicycle network development follows a slow and piecewise process, without taking into account the structural complexity of transportation networks. Here we explore systematically the topological limitations of urban bicycle network development. For 62 cities we study different variations of growing a synthetic bicycle network between an arbitrary set of points routed on the urban street network. We find initially decreasing returns on investment until a critical threshold, posing fundamental consequences to sustainable urban planning: cities must invest into bicycle networks with the right growth strategy, and persistently, to surpass a critical mass. We also find pronounced overlaps of synthetically grown networks in cities with well-developed existing bicycle networks, showing that our model reflects reality. Growing networks from scratch makes our approach a generally applicable starting point for sustainable urban bicycle network planning with minimal data requirements.},
	language = {en},
	number = {1},
	urldate = {2025-11-11},
	journal = {Scientific Reports},
	publisher = {Nature Publishing Group},
	author = {Szell, Michael and Mimar, Sayat and Perlman, Tyler and Ghoshal, Gourab and Sinatra, Roberta},
	month = apr,
	year = {2022},
	keywords = {Complex networks, Applied mathematics, Computational science},
	pages = {6765},
	file = {Full Text PDF:/home/eugenividaltortosa/snap/zotero-snap/common/Zotero/storage/CR7AS3FF/Szell et al. - 2022 - Growing urban bicycle networks.pdf:application/pdf},
}

@article{herfort_spatio-temporal_2023,
	title = {A spatio-temporal analysis investigating completeness and inequalities of global urban building data in {OpenStreetMap}},
	volume = {14},
	copyright = {2023 The Author(s)},
	issn = {2041-1723},
	url = {https://www.nature.com/articles/s41467-023-39698-6},
	doi = {10.1038/s41467-023-39698-6},
	abstract = {OpenStreetMap (OSM) has evolved as a popular dataset for global urban analyses, such as assessing progress towards the Sustainable Development Goals. However, many analyses do not account for the uneven spatial coverage of existing data. We employ a machine-learning model to infer the completeness of OSM building stock data for 13,189 urban agglomerations worldwide. For 1,848 urban centres (16\% of the urban population), OSM building footprint data exceeds 80\% completeness, but completeness remains lower than 20\% for 9,163 cities (48\% of the urban population). Although OSM data inequalities have recently receded, partially as a result of humanitarian mapping efforts, a complex unequal pattern of spatial biases remains, which vary across various human development index groups, population sizes and geographic regions. Based on these results, we provide recommendations for data producers and urban analysts to manage the uneven coverage of OSM data, as well as a framework to support the assessment of completeness biases.},
	language = {en},
	number = {1},
	urldate = {2025-11-11},
	journal = {Nature Communications},
	publisher = {Nature Publishing Group},
	author = {Herfort, Benjamin and Lautenbach, Sven and Porto de Albuquerque, João and Anderson, Jennings and Zipf, Alexander},
	month = jul,
	year = {2023},
	note = {153 citations (Semantic Scholar/DOI) [2025-11-13]},
	keywords = {Geography, Developing world, Environmental social sciences},
	pages = {3985},
	file = {Full Text:/home/eugenividaltortosa/snap/zotero-snap/common/Zotero/storage/RIHP65NJ/Herfort et al. - 2023 - A spatio-temporal analysis investigating completeness and inequalities of global urban building data.pdf:application/pdf},
}

