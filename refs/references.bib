	year = {2020},
	note = {2 citations (Semantic Scholar/DOI) [2025-05-06]
Conference Name: XXIV ISPRS Congress, Commission IV (Volume V-4-2020) - 2020 edition},
	keywords = {OpenStreetMap, Regression, Belief Theory, Intrinsic and Extrinsic Quality, Multi-criteria Data Matching, Reference Data, Spatial Accuracy, Spatial Data},
	pages = {39--47},
	file = {Full Text PDF:/home/eugenividaltortosa/snap/zotero-snap/common/Zotero/storage/GSTSMKB3/Maidaneh Abdi et al. - 2020 - A REGRESSION MODEL OF SPATIAL ACCURACY PREDICTION FOR OPENSTREETMAP BUILDINGS.pdf:application/pdf},
