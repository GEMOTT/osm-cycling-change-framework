streets_in_sample <- st_intersection(streets, tract_union)

point_colors <- c("osm_cycleway" = "blue", "osm_general" = "red")
tmap_mode("plot")

final_plot <- tm_shape(streets_in_sample) +
  tm_lines(col = "gray70", lwd = 0.6) +
  tm_shape(sampled_tracts) +
  tm_borders(col = "black", lwd = 1) +
  tm_shape(samples_all_wgs) +
  tm_dots(col = "source", palette = point_colors, size = NA, border.col = "white", title = "Validation Source") +
  tm_text("photo_id", size = 0.6, col = "black", just = "bottom") 

saveRDS(final_plot, file = "figs/final_map_interactive.rds")

