```{r}
#| eval: false
#| include: false
# ================================================================
# 4. NETWORK POINT SAMPLING FROM OSM (MIDPOINT-BASED)
# ================================================================

# Setup
x_fp <- 2  # points per tract from cycleways
x_fn <- 2  # points per tract from general road network
target_crs <- 25831
gsv_api_key <- "[REDACTED_GOOGLE_API_KEY]"
sampled_tracts <- st_transform(sampled_tracts, 25831)

# Limit to 3 tracts and assign tract IDs
sampled_tracts <- st_transform(sampled_tracts, target_crs)
# sampled_tracts <- sampled_tracts[1:3, ]
sampled_tracts$tract_id <- 1:nrow(sampled_tracts)


# Load or read OSM data
osm_file <- "data/osm_streets_barcelona.rds"
osm_streets <- if (!file.exists(osm_file)) {
  opq("Barcelona") %>%
    add_osm_feature(key = "highway") %>%
    osmdata_sf() %>%
    { saveRDS(., osm_file); . }
} else {
  readRDS(osm_file)
}

streets <- st_transform(osm_streets$osm_lines, 25831)

required_cols <- c("cycleway", "cycleway:left", "cycleway:right", "bicycle", "route") # Fill missing OSM columns
streets[setdiff(required_cols, names(streets))] <- NA

cycleway_lines <- streets %>% # Classify lines
  filter(
    highway == "cycleway" |
    cycleway %in% c("lane", "track", "separate", "opposite", "opposite_lane", "opposite_track") |
    `cycleway:left` %in% c("lane", "track", "separate", "opposite", "opposite_lane", "opposite_track") |
    `cycleway:right` %in% c("lane", "track", "separate", "opposite", "opposite_lane", "opposite_track")
  )

general_lines <- streets %>%
  filter(highway %in% c("primary", "secondary", "tertiary", "residential", "living_street", "service"))

# Sampling function (minimal and working)
sample_points_from_lines <- function(lines, tract_geom, tract_id, n_points, source_label) {
  # Slight buffer for more forgiving intersection
  buffer_geom <- st_buffer(tract_geom, 5)

  # Get lines that intersect the buffered geometry
  lines_in <- lines[st_intersects(lines, buffer_geom, sparse = FALSE), ]
  if (nrow(lines_in) == 0) return(NULL)

  # Keep only valid geometry types
  valid_lines <- st_geometry(lines_in)[st_geometry_type(lines_in) %in% c("LINESTRING", "MULTILINESTRING")]
  if (length(valid_lines) == 0) return(NULL)

  # Sample many points
  sampled <- tryCatch(
    suppressWarnings(st_line_sample(valid_lines, n = max(n_points * 10, 10), type = "random")),
    error = function(e) st_sfc()
  )
  if (length(sampled) == 0) return(NULL)

  sampled <- st_cast(sampled, "POINT")

  # Keep only those points that fall within the actual tract (not just buffer)
  sampled <- sampled[st_within(sampled, tract_geom, sparse = FALSE)]

  if (length(sampled) == 0) return(NULL)

  if (length(sampled) > n_points) {
    sampled <- sampled[sample(seq_along(sampled), n_points)]
  }

  df <- data.frame(
    tract_id = rep(tract_id, length(sampled)),
    source = rep(source_label, length(sampled)),
    stringsAsFactors = FALSE
  )

  st_sf(df, geometry = sampled, crs = st_crs(tract_geom))
}


# Modified mapping process with better error handling
samples_all <- purrr::map_dfr(1:nrow(sampled_tracts), function(i) {
  tract <- sampled_tracts[i, ]
  geom <- st_geometry(tract)
  
  # ⬇️ OVERSAMPLE HERE — increase from 2 to e.g., 30
  out1 <- sample_points_from_lines(cycleway_lines, geom, tract$tract_id, 50, "osm_cycleway")
  out2 <- sample_points_from_lines(general_lines, geom, tract$tract_id, 50, "osm_general")
  
  # Debugging output
  print(paste("Tract", tract$tract_id, 
              "| Cycleway lines in:", ifelse(is.null(out1), 0, nrow(out1)),
              "| General lines in:", ifelse(is.null(out2), 0, nrow(out2))))
  
  # Safely combine results
  result <- tryCatch({
    if (!is.null(out1) && !is.null(out2)) {
      bind_rows(out1, out2)
    } else if (!is.null(out1)) {
      out1
    } else if (!is.null(out2)) {
      out2
    } else {
      NULL
    }
  }, error = function(e) {
    warning(paste("Error combining results for tract", tract$tract_id, ":", e$message))
    NULL
  })
  
  return(result)
}, .id = "tract_num")

# id_photo not appearing properly
samples_all <- samples_all %>%
  mutate(photo_id = row_number())
```

```{r}
#| eval: false
#| include: false
# ================================================================
# 5. ADD GSV DATE + GENERATE LINK
# ================================================================
samples_all_wgs <- st_transform(samples_all, 4326)

get_gsv_date <- function(lat, lon, key) {
  url <- paste0("https://maps.googleapis.com/maps/api/streetview/metadata?",
                "location=", lat, ",", lon, "&key=", key)
  tryCatch({
    res <- fromJSON(url)
    if (!is.null(res$date)) res$date else NA
  }, error = function(e) NA)
}

samples_all_wgs <- samples_all_wgs %>%
  mutate(
    gsv_date = map_chr(seq_len(n()), function(i) {
      coords <- st_coordinates(samples_all_wgs[i, ])
      get_gsv_date(coords[2], coords[1], gsv_api_key)
    }),
    gsv_maps_url = map_chr(seq_len(n()), function(i) {
      coords <- st_coordinates(samples_all_wgs[i, ])
      paste0("https://www.google.com/maps/@?api=1&map_action=pano&viewpoint=", coords[2], ",", coords[1])
    })
  )

samples_all_wgs <- samples_all_wgs %>%
  left_join(
    st_drop_geometry(sampled_tracts)[, c("tract_id", "stratum_id")],
    by = "tract_id"
  )

# Filter by year(s) of interest
samples_all_recent <- samples_all_wgs %>%
  mutate(gsv_year = as.integer(substr(gsv_date, 1, 4))) %>%
  filter(gsv_year >= 2023)

samples_final <- samples_all_recent %>%
  group_by(tract_id, source) %>%
  slice_sample(n = 2) %>%
  ungroup()
```

```{r}
#| eval: false
#| include: false
# ================================================================
# 6. EXPORT TO GEOJSON AND EXCEL WITH CLICKABLE LINKS
# ================================================================

st_write(samples_all_wgs, "data/validation/sample_points_with_links.geojson", delete_dsn = TRUE)

samples_df <- samples_all_wgs %>%
  st_drop_geometry() %>%
  mutate(
    lat = st_coordinates(samples_all_wgs)[, 2],
    lon = st_coordinates(samples_all_wgs)[, 1],
    clickable_url = paste0('=HYPERLINK("', gsv_maps_url, '", "View")')
  )

wb <- createWorkbook()
addWorksheet(wb, "Sample Points")
writeData(wb, "Sample Points", samples_df)
link_col <- which(names(samples_df) == "clickable_url")
writeFormula(wb, "Sample Points", samples_df$clickable_url, startCol = link_col, startRow = 2)
saveWorkbook(wb, "data/validation/sample_points_with_links.xlsx", overwrite = TRUE)
```

