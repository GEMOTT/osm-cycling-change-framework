```{r}
samples_all_wgs <- samples_all_wgs %>%
  left_join(st_drop_geometry(sampled_tracts[, c("tract_id", "stratum_id")]),
            by = "tract_id")

availability_by_stratum <- samples_all_wgs %>%
  mutate(
    gsv_year = as.integer(substr(gsv_date, 1, 4)),
    has_2024_plus = !is.na(gsv_year) & gsv_year > 2023
  ) %>%
  st_drop_geometry() %>%
  group_by(stratum_id) %>%
  summarise(
    total_points = n(),
    n_2024_plus = sum(has_2024_plus),
    pct_2024_plus = round(100 * n_2024_plus / total_points, 1),
    .groups = "drop"
  )

print(availability_by_stratum)

library(ggplot2)

availability_by_stratum %>%
  separate(stratum_id, into = c("density", "centrality"), sep = "_") %>%
  ggplot(aes(x = centrality, y = density, fill = pct_2024_plus)) +
  geom_tile(color = "white") +
  geom_text(aes(label = paste0(pct_2024_plus, "%")), size = 3) +
  scale_fill_gradient(low = "red", high = "green") +
  labs(title = "Recent GSV Availability by Stratum (2024+)", fill = "% 2024+") +
  theme_minimal()

```




