@article{raifer_oshdb_2019,
	title = {{OSHDB}: a framework for spatio-temporal analysis of {OpenStreetMap} history data},
	volume = {4},
	issn = {2363-7501},
	url = {https://opengeospatialdata.springeropen.com/articles/10.1186/s40965-019-0061-3},
	doi = {10.1186/s40965-019-0061-3},
	shorttitle = {{OSHDB}},
	abstract = {{OpenStreetMap} ({OSM}) is a collaborative project collecting geographical data of the entire world. The level of detail of {OSM} data and its data quality vary much across different regions and domains. In order to analyse such variations it is often necessary to research the history and evolution of the {OSM} data. The {OpenStreetMap} History Database ({OSHDB}) is a new data analysis tool for spatio-temporal geographical vector data. It is specifically optimized for working with {OSM} history data on a global scale and allows one to investigate the data evolution and user contributions in a flexible way. Benefits of the {OSHDB} are for example: to facilitate accessing {OSM} history data as a research subject and to assess the quality of {OSM} data by using intrinsic measures. This article describes the requirements of such a system and the resulting technical implementation of the {OSHDB}: the {OSHDB} data model and its application programming interface.},
	pages = {3},
	number = {1},
	journaltitle = {Open Geospatial Data, Software and Standards},
	shortjournal = {Open geospatial data, softw. stand.},
	author = {Raifer, Martin and Troilo, Rafael and Kowatsch, Fabian and Auer, Michael and Loos, Lukas and Marx, Sabrina and Przybill, Katharina and Fendrich, Sascha and Mocnik, Franz-Benjamin and Zipf, Alexander},
	urldate = {2025-03-18},
	date = {2019-12},
	langid = {english},
	note = {70 citations (Semantic Scholar/{DOI}) [2025-03-18]},
	file = {PDF:/home/eugeni/snap/zotero-snap/common/Zotero/storage/AP329W8G/Raifer et al. - 2019 - OSHDB a framework for spatio-temporal analysis of OpenStreetMap history data.pdf:application/pdf},
}

@article{barron_comprehensive_2014,
	title = {A Comprehensive Framework for Intrinsic {OpenStreetMap} Quality Analysis},
	volume = {18},
	rights = {© 2013 John Wiley \& Sons Ltd},
	issn = {1467-9671},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/tgis.12073},
	doi = {10.1111/tgis.12073},
	abstract = {{OpenStreetMap} ({OSM}) is one of the most popular examples of a Volunteered Geographic Information ({VGI}) project. In the past years it has become a serious alternative source for geodata. Since the quality of {OSM} data can vary strongly, different aspects have been investigated in several scientific studies. In most cases the data is compared with commercial or administrative datasets which, however, are not always accessible due to the lack of availability, contradictory licensing restrictions or high procurement costs. In this investigation a framework containing more than 25 methods and indicators is presented, allowing {OSM} quality assessments based solely on the data's history. Without the usage of a reference data set, approximate statements on {OSM} data quality are possible. For this purpose existing methods are taken up, developed further, and integrated into an extensible open source framework. This enables arbitrarily repeatable intrinsic {OSM} quality analyses for any part of the world.},
	pages = {877--895},
	number = {6},
	journaltitle = {Transactions in {GIS}},
	author = {Barron, Christopher and Neis, Pascal and Zipf, Alexander},
	urldate = {2025-03-18},
	date = {2014},
	langid = {english},
	note = {70 citations (Semantic Scholar/{DOI}) [2025-03-18]
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/tgis.12073},
	file = {Snapshot:/home/eugeni/snap/zotero-snap/common/Zotero/storage/YDW2BJHK/tgis.html:text/html},
}

