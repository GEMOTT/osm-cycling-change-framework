@article{zhang_road_2018,
	title = {Road Extraction by Deep Residual U-Net},
	volume = {15},
	rights = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/{IEEE}.html},
	issn = {1545-598X, 1558-0571},
