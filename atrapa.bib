	volume = {41},
	issn = {13698478},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S1369847816301103},
	doi = {10.1016/j.trf.2016.06.015},
	abstract = {This paper investigated the factors inﬂuencing the acceptability of an assumed congestion pricing scenario in a commercial center of Nanjing China. A hierarchical structural model was proposed to analyze determinants of the acceptability according to the planned behavior theory and norm activation theory combined with the evaluations of the measure. Furthermore, the role of the socio-demographic in affecting acceptability was examined. A sample of 897 Chinese car users was used to test the model. Results of the {SEM} indicate that perceived fairness and freedom seem to be strong determinants of car users’ congestion pricing acceptability. Personal norm and perceived behavior control are proved to be additional direct predictors of acceptability. In contrast to previous studies, perceived effectiveness is not signiﬁcantly related to fairness. Furthermore, results indicate a low association of socio-demographic variables with congestion pricing acceptability.},
	pages = {104--112},
	journaltitle = {Transportation Research Part F: Traffic Psychology and Behaviour},
