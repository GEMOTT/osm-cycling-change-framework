	langid = {english},
	file = {PDF:/home/eugeni/snap/zotero-snap/common/Zotero/storage/PNURV388/Zacharopoulou et al. - 2021 - Assessment and Visualization of OSM Consistency for European Cities.pdf:application/pdf},
}

