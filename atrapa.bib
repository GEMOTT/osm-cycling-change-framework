	url = {https://linkinghub.elsevier.com/retrieve/pii/S0967070X11000473},
	doi = {10.1016/j.tranpol.2011.03.006},
	shorttitle = {The unexpected “yes”},
	abstract = {Several authors have argued that acceptability for road pricing is likely to increase with familiarity. The experiences in Stockholm, where a trial period with congestion charges changed the public opinion from negative to positive, support this hypothesis. Analysing acceptability and attitudes in Stockholm allows us to study a situation where the population is in fact familiar with congestion charges, and explore what the decisive factors for acceptability are in such a situation. By analysing a survey collected after the referendum and the subsequent reintroduction of the charges, we analyse the prerequisites to achieve acceptability given that the public is familiar with congestion charges.},
	pages = {636--647},
	number = {4},
	journaltitle = {Transport Policy},
